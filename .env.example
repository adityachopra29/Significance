# ---- Database ----
DATABASE_URL=postgresql+psycopg2://aie:aie@127.0.0.1:5433/aie

# ---- LLM (provider-agnostic) ----
# LLM_PROVIDER one of: heuristic | openai | anthropic | gemini
# "heuristic" runs with NO API key (keyword-based fallback) so the system works out of the box.
LLM_PROVIDER=heuristic
LLM_MODEL=
LLM_API_KEY=

# ---- Universe / market data ----
# Yahoo symbol used as the "market" in the event-study market model.
# ^NSEI = Nifty 50, ^BSESN = Sensex (^CRSLDX / Nifty 500 is not on Yahoo)
MARKET_INDEX=^NSEI

# ---- Ingestion ----
# Seconds between BSE announcement polls during market hours.
POLL_INTERVAL_SECONDS=60
# How many days back to pull on first ingestion run (and when adding a new stock).
BACKFILL_DAYS=30

# ---- Event study ----
ESTIMATION_WINDOW_DAYS=120

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
