# ---- Database ----
DATABASE_URL=postgresql+psycopg2://aie:aie@127.0.0.1:5433/aie

# ---- LLM (provider-agnostic) ----
# LLM_PROVIDER one of: openai | anthropic | gemini
# The worker requires a real provider + API key. If omitted, analysis rows fail with a clear error.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# ---- Universe / market data ----
# Yahoo symbol used as the "market" in the event-study market model.
# ^NSEI = Nifty 50, ^BSESN = Sensex (^CRSLDX / Nifty 500 is not on Yahoo)
MARKET_INDEX=^NSEI

# ---- Ingestion ----
# Seconds between BSE announcement polls during market hours.
POLL_INTERVAL_SECONDS=60
# How many days back to pull on first ingestion run (and when adding a new stock).
BACKFILL_DAYS=30
# Store backfill history in the live feed but do not queue it for LLM analysis (production default).
ANALYZE_BACKFILL=false
# Only analyze announcements first ingested on/after this ISO timestamp (clears restored DB backlog).
# ANALYZE_FROM=2026-06-19T00:00:00+00:00
# Include NSE corporate announcements alongside BSE (set false if NSE blocks cloud IP).
NSE_INGEST_ENABLED=true
# Optional HTTP proxy for NSE (residential/ISP). Required on many AWS/Azure hosts.
# NSE_PROXY_URL=http://user:pass@host:port
# Poll and backfill announcements when the worker starts (default false — load universe first).
INGEST_ON_STARTUP=false

# ---- Event study ----
ESTIMATION_WINDOW_DAYS=120

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Production (Render / cloud) ----
# PURGE_ENABLED=false
# INGEST_ON_STARTUP=true          # worker only
# NSE_PROXY_URL=                  # if NSE announcements 403 from cloud
